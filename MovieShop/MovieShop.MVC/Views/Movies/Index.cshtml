@model MovieShop.ApplicationCore.Models.PagedResultSetModel<MovieShop.ApplicationCore.Models.MovieCardModel>

@{
   string genreDisplayName = ViewBag.GenreName ?? "Movies";
    ViewData["Title"] = genreDisplayName;
    int genreId = ViewBag.GenreId;// Controller se genreId mil raha hai
}
<div class="container-fluid px-4 mt-4">
    <div class="row mb-4">
        <div class="col-12 border-start border-danger border-5">
            <h2 class="text-white ms-3 fw-bold">@genreDisplayName</h2>
        </div>
    </div>
<div class="container-fluid px-4 mt-4">
    <div class="row">
        @if (Model != null && Model.Data.Any())
        {
            foreach (var movie in Model.Data)
            {
                <partial name="_MovieCard" model="movie" />
            }
        }
        else
        {
            <div class="col-12 text-center mt-5"><h3 class="text-white">No movies found.</h3></div>
        }
    </div>

    <nav aria-label="Page navigation" class="mt-5 mb-5">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link bg-dark text-white border-secondary" asp-action="Genre" asp-route-id="@genreId" asp-route-pageNumber="@(Model.PageIndex - 1)">Previous</a>
            </li>

            @{
                int startPageG = Math.Max(1, Model.PageIndex - 2);
                int endPageG = Math.Min(Model.TotalPages, Model.PageIndex + 2);
            }

            @if (startPageG > 1)
            {
                <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Genre" asp-route-id="@genreId" asp-route-pageNumber="1">1</a></li>
                @if (startPageG > 2) { <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li> }
            }

            @for (int i = startPageG; i <= endPageG; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link @(i == Model.PageIndex ? "bg-danger border-danger text-white" : "bg-dark text-white border-secondary")" 
                       asp-action="Genre" asp-route-id="@genreId" asp-route-pageNumber="@i">@i</a>
                </li>
            }

            @if (endPageG < Model.TotalPages)
            {
                @if (endPageG < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li> }
                <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Genre" asp-route-id="@genreId" asp-route-pageNumber="@Model.TotalPages">@Model.TotalPages</a></li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link bg-dark text-white border-secondary" asp-action="Genre" asp-route-id="@genreId" asp-route-pageNumber="@(Model.PageIndex + 1)">Next</a>
            </li>
        </ul>
    </nav>
</div>