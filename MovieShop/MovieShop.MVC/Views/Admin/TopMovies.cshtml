@model IEnumerable<MovieShop.ApplicationCore.Models.TopPurchasedMovieModel>

@{
    ViewData["Title"] = "Top Movies";
    
    // URL parameters ko zinda rakhne ke liye
    var userId = Context.Request.Query["userId"];
    var userName = Context.Request.Query["name"];
    var isAdminStr = Context.Request.Query["isAdmin"];
    int index = 1;
}

<div class="container-fluid min-vh-100 p-4" style="background-color: #141414;">
    <h2 class="fw-bold mb-4 border-bottom border-danger pb-2 d-inline-block text-white">
        <i class="fa-solid fa-chart-line text-danger me-2"></i> Top Purchased Movies
    </h2>

    <div class="p-3 mb-4 rounded shadow-lg d-flex justify-content-center" style="background-color: #222; border: 1px solid #333;">
        <form asp-controller="Admin" asp-action="TopMovies" method="get" class="d-flex flex-wrap align-items-center gap-3">
            
            <input type="hidden" name="userId" value="@userId" />
            <input type="hidden" name="name" value="@userName" />
            <input type="hidden" name="isAdmin" value="@isAdminStr" />

            <label class="fw-bold text-secondary"><i class="fa-solid fa-calendar-days me-1"></i> From Date</label>
            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control netflix-input w-auto shadow-none" />
            
            <label class="fw-bold text-secondary"><i class="fa-solid fa-calendar-days me-1"></i> To Date</label>
            <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control netflix-input w-auto shadow-none" />
            
            <button type="submit" class="btn btn-netflix px-4 rounded-1 shadow">
                <i class="fa-solid fa-magnifying-glass me-1"></i> Search
            </button>

            @if (!string.IsNullOrEmpty((string)ViewBag.FromDate) || !string.IsNullOrEmpty((string)ViewBag.ToDate))
            {
                <a asp-controller="Admin" asp-action="TopMovies" 
                   asp-route-userId="@userId" asp-route-name="@userName" asp-route-isAdmin="@isAdminStr" 
                   class="btn btn-outline-light rounded-1 px-3">
                   <i class="fa-solid fa-xmark"></i> Clear
                </a>
            }
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive rounded shadow-lg" style="border: 1px solid #333;">
            <table class="table table-dark mb-0 align-middle netflix-table">
                <thead style="background-color: #000; border-bottom: 2px solid #E50914;">
                    <tr>
                        <th scope="col" class="py-3 px-4 text-secondary fs-6 text-uppercase"># Rank</th>
                        <th scope="col" class="py-3 px-4 text-secondary fs-6 text-uppercase">Movie Title</th>
                        <th scope="col" class="py-3 px-4 text-secondary fs-6 text-uppercase text-end">Total Purchases</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom border-secondary">
                            <td class="py-3 px-4 fw-bold fs-5 text-danger">@index</td>
                            <td class="py-3 px-4 fw-bold fs-5 text-white">@item.Title</td>
                            <td class="py-3 px-4 fw-bold fs-5 text-end text-success">
                                @item.TotalPurchases <i class="fa-solid fa-ticket ms-1 text-secondary opacity-50"></i>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-center align-items-center mt-5">
            <div class="text-center p-5 rounded-4 border border-secondary shadow-lg" style="background-color: #222; max-width: 600px;">
                <i class="fa-solid fa-magnifying-glass-chart fa-4x text-secondary mb-4 opacity-50"></i>
                <h2 class="fw-bold text-white mb-3">No Movies Found</h2>
                <p class="text-secondary fs-5 mb-4">
                    We couldn't find any movie purchases in the selected date range. Try adjusting your dates to discover the top hits!
                </p>
                <a asp-controller="Admin" asp-action="TopMovies" 
                   asp-route-userId="@userId" asp-route-name="@userName" asp-route-isAdmin="@isAdminStr" 
                   class="btn btn-netflix rounded-pill px-4 py-2 fs-5 shadow">
                    <i class="fa-solid fa-rotate-left me-2"></i> Reset Filters
                </a>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        /* Netflix Style CSS */
        .netflix-input {
            background-color: #333 !important;
            color: #fff !important;
            border: 1px solid #555 !important;
        }
        .netflix-input:focus {
            border-color: #E50914 !important;
            background-color: #444 !important;
        }
        /* Style datepicker calendar icon to white */
        ::-webkit-calendar-picker-indicator {
            filter: invert(1);
        }
        .btn-netflix {
            background-color: #E50914;
            color: white;
            font-weight: bold;
            transition: all 0.3s;
        }
        .btn-netflix:hover {
            background-color: #b20710;
            color: white;
            transform: scale(1.05);
        }
        .netflix-table {
            background-color: #141414;
        }
        .netflix-table tbody tr {
            transition: background-color 0.3s, transform 0.2s, border-left 0.2s;
            border-left: 0px solid transparent;
        }
        /* Hover Effect: Row zoom and Red left border */
        .netflix-table tbody tr:hover {
            background-color: #2b2b2b !important;
            transform: scale(1.005);
            border-left: 4px solid #E50914;
            cursor: pointer;
        }
    </style>
}