<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MovieShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        .dropdown-item:hover { background-color: #343a40; color: #ff0000 !important; }
        .navbar-brand { letter-spacing: 1px; }
        .nav-link { transition: color 0.3s; }
        .nav-link:hover { color: #dc3545 !important; }
    </style>
</head>
<body class="bg-dark text-white d-flex flex-column min-vh-100">

   @{
    // URL se data nikalna
    var userId = Context.Request.Query["userId"];
    var userName = Context.Request.Query["name"];
    
    // YAHAN CHANGE KAREIN: isse "True", "true", "TRUE" sab kaam karega
    var isAdminStr = Context.Request.Query["isAdmin"].ToString();
    var isAdmin = isAdminStr.Equals("true", StringComparison.OrdinalIgnoreCase);

    var routeData = new Dictionary<string, string> {
        { "userId", userId.ToString() },
        { "name", userName.ToString() },
        { "isAdmin", isAdmin ? "true" : "false" }
    };
}

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-secondary shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand text-danger fw-bold fs-3" asp-controller="Home" asp-action="Index" 
                   asp-all-route-data="routeData">MOVIE SHOP <i class="fa-solid fa-film ms-1"></i></a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-bold text-uppercase text-secondary" href="#" id="genreDrop" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Genres
                            </a>
                            <ul class="dropdown-menu bg-dark border-secondary shadow" aria-labelledby="genreDrop" style="max-height: 400px; overflow-y: auto;">
                                @await Component.InvokeAsync("Genres")
                            </ul>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (!string.IsNullOrEmpty(userName))
                        {
                            @if (isAdmin)
                            {
                                <div class="dropdown me-3">
                                    <button class="btn btn-dark dropdown-toggle fw-bold text-uppercase border-0" type="button" data-bs-toggle="dropdown">
                                        Admin
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary shadow">
                                       <li>
    <a class="dropdown-item text-white" asp-controller="Admin" asp-action="TopMovies" asp-all-route-data="routeData">
        Top Movies
    </a>
</li>
                                        <li><a class="dropdown-item text-white" href="#">Create Movie</a></li>
                                    </ul>
                                </div>
                            }

                            <div class="dropdown">
                                <button class="btn btn-outline-light dropdown-toggle border-0 fw-bold" type="button" id="userMenu" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-circle-user fs-4 me-1 align-middle"></i> @userName
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end bg-dark border-secondary shadow" style="min-width: 180px;">
                                    @if (!isAdmin)
                                    {
                                        <li>
                                            <a class="dropdown-item text-white py-2" asp-controller="User" asp-action="Purchases" asp-all-route-data="routeData">
                                                <i class="fa-solid fa-briefcase me-2"></i> Movies (Purchases)
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-white py-2" href="#">
                                                <i class="fa-solid fa-star me-2"></i> Favorites
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-white py-2" href="#">
                                                <i class="fa-solid fa-user-gear me-2"></i> Account
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item text-white py-2" href="#"><i class="fa-solid fa-chart-line me-2"></i> Dashboard</a></li>
                                    }
                                    
                                    <li><hr class="dropdown-divider bg-secondary"></li>
                                    <li>
                                        <a class="dropdown-item text-danger fw-bold py-2" asp-controller="Home" asp-action="Index">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light me-2 btn-sm px-3 fw-bold">LOGIN</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-danger btn-sm text-white px-3 fw-bold">REGISTER</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-black text-center text-secondary py-3 border-top border-secondary mt-auto">
        <div class="container">
            &copy; 2026 - MovieShop - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-secondary">Privacy</a>
        </div>
    </footer>

   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Scripts section *@
    @await RenderSectionAsync("Scripts", required: false)

    @* Styles section *@
    @await RenderSectionAsync("Styles", required: false)

</body> @* <-- Check karein ki ye tag sahi hai aur extra characters nahi hain *@
</html>