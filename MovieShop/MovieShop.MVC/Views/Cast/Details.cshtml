@model MovieShop.ApplicationCore.Models.CastDetailsResponseModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <div class="row mb-5 bg-dark p-4 rounded shadow">
        <div class="col-md-3 text-center text-md-start">
            <img src="@Model.ProfilePath" class="img-fluid rounded shadow-lg border border-secondary" alt="@Model.Name" style="max-height: 400px; object-fit: cover;" onerror="this.src='/images/default-avatar.png';"/>
        </div>
        <div class="col-md-9 mt-4 mt-md-0 d-flex flex-column justify-content-center">
            <h1 class="fw-bolder" style="font-size: 3rem;">@Model.Name</h1>
            <hr class="border-secondary" />
            <p class="fs-5 text-muted"><i class="fa-solid fa-venus-mars me-2"></i> <strong>Gender:</strong> @Model.Gender</p>
            <div class="mt-3">
                <a href="@Model.TmdbUrl" target="_blank" class="btn btn-outline-info rounded-pill px-4"><i class="fa-solid fa-link me-2"></i>TMDB Profile</a>
            </div>
        </div>
    </div>

    <h3 class="mb-4 border-start border-danger border-4 ps-2"><i class="fa-solid fa-film text-netflix me-2"></i> Filmography (@Model.Movies.Count())</h3>
    <div class="row">
        @foreach (var movie in Model.Movies)
        {
            <partial name="_MovieCard" model="movie" />
        }
    </div>
</div>